# plan9.fish — fish shell environment setup for plan9port.
# Source this file from your config.fish:
#   source /usr/local/plan9/shell/plan9.fish
#
# This file is generated by SETUP with the correct PLAN9 path baked in.

set -gx PLAN9 /usr/local/plan9

# Mail (upas) — MAILROOT and UPASLIB default to $PLAN9/mail and $PLAN9/mail/lib.
# Uncomment and edit these only if you have relocated the mail directory.
#set -gx MAILROOT "$PLAN9/mail"
#set -gx UPASLIB "$PLAN9/mail/lib"

if not contains $PLAN9/bin $fish_user_paths
    fish_add_path $PLAN9/bin
end

# Acme font defaults — source fonts.sh (shared with bash/zsh/rc).
# Override fixfont/varfont after this line to use different fonts.
if not set -q fixfont
    bass source $PLAN9/shell/fonts.sh
end
if not set -q acmedump
    set -gx acmedump $HOME/acme.dump
end
