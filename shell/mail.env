# mail.rc — optional upas environment overrides.
#
# UPASLIB and MAILROOT default to $PLAN9/mail/lib and $PLAN9/mail respectively.
# You only need to set these if you have moved the mail directory elsewhere.
# The same variables are documented (commented out) in $PLAN9/shell/plan9.sh.in.
#
# To use: uncomment and edit the lines below, then source this file:
#   . $PLAN9/mail/mail.rc
#
#UPASLIB=$PLAN9/mail/lib
#MAILROOT=$PLAN9/mail
