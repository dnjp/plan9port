# plan9.rc — rc shell environment setup for plan9port.
# Source this file from your .profile or rc startup:
#   . /usr/local/plan9/shell/plan9.rc
#
# This file is generated by SETUP with the correct PLAN9 path baked in.

PLAN9=/usr/local/plan9

if(! ~ $PLAN9/bin $path)
	path=($PLAN9/bin $path)

# Acme font defaults — rc doesn't source sh files directly; set the same
# values here, kept in sync with shell/fonts.sh.in.
if(~ $#fixfont 0)
	fixfont=/mnt/font/Menlo-Regular/15a/font,/mnt/font/Menlo-Regular/30a/font
if(~ $#varfont 0)
	varfont=/mnt/font/LucidaGrande/14a/font,/mnt/font/LucidaGrande/28a/font
if(~ $#acmedump 0)
	acmedump=$home/acme.dump

# Mail (upas) — MAILROOT and UPASLIB default to $PLAN9/mail and $PLAN9/mail/lib.
# Uncomment and edit these only if you have relocated the mail directory.
#if(~ $#MAILROOT 0) MAILROOT=$PLAN9/mail
#if(~ $#UPASLIB 0)  UPASLIB=$PLAN9/mail/lib
