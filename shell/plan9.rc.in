# plan9.rc — rc shell environment setup for plan9port.
# Source this file from your .profile or rc startup:
#   . /usr/local/plan9/shell/plan9.rc
#
# This file is generated by SETUP with the correct PLAN9 path baked in.

PLAN9=/usr/local/plan9

if(! ~ $PLAN9/bin $path)
	path=($PLAN9/bin $path)

# Acme font settings. Override these after sourcing this file.
# See plan9.sh for details on the HiDPI comma-separated pair format.
if(~ $#fixfont 0)
	fixfont=/mnt/font/Menlo-Regular/14a/font,/mnt/font/Menlo-Regular/28a/font
if(~ $#varfont 0)
	varfont=/mnt/font/LucidaGrande/13a/font,/mnt/font/LucidaGrande/26a/font
if(~ $#acmedump 0)
	acmedump=$home/acme.dump
