# plan9.sh — POSIX sh/bash/zsh environment setup for plan9port.
# Source this file from your shell profile:
#   . /usr/local/plan9/shell/plan9.sh
#
# This file is generated by SETUP with the correct PLAN9 path baked in.
# Do not edit the copy in $PLAN9/shell/; edit the source in the repo instead.

PLAN9=/usr/local/plan9
export PLAN9

case ":${PATH}:" in
*":${PLAN9}/bin:"*)
	;;
*)
	PATH="${PATH}:${PLAN9}/bin"
	export PATH
	;;
esac

# Acme font defaults — defined in fonts.sh so all shells share one source of truth.
. "${PLAN9}/shell/fonts.sh"

# Path to an acme dump file to restore on startup.
: "${acmedump:=$HOME/acme.dump}"
export acmedump

# Mail (upas) — UPASLIB and MAILROOT default to $PLAN9/mail and $PLAN9/mail/lib.
# Uncomment and edit these only if you have relocated the mail directory.
#export MAILROOT="${PLAN9}/mail"
#export UPASLIB="${PLAN9}/mail/lib"

# Interactive shell setup inside a plan9port app (acme, sam, 9term).
# When $INSIDE_P9P is set, source p9p-session.sh from your ~/.bashrc or
# ~/.zshrc to get the right terminal behaviour (TERM=dumb, awd, PAGER=nobs,
# cd override, etc.).  Example:
#
#   if [ -n "$INSIDE_P9P" ]; then
#       . $PLAN9/shell/p9p-session.sh
#   else
#       # normal interactive shell setup (completions, plugins, etc.)
#   fi
