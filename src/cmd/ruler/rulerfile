# Ruler rules (plumber-style). Blank line terminates each rule set.
# See https://9fans.github.io/plan9port/man/man7/plumb.html
# All rules: client=acme, event=new (new window opened).

# cpp
client is acme
event is open
query matches '*.cc'
query matches '*.cpp'
query matches '*.hpp'
query matches '*.cxx'
query matches '*.hxx'
rule set comfmt '// %s'
rule set tabstop 2
rule set tabexpand on

# java
client is acme
event is open
query matches '*.java'
rule set comfmt '// %s'
rule set tabstop 2
rule set tabexpand on

# javascript
client is acme
event is open
query matches '*.js'
query matches '*.ts'
rule set comfmt '// %s'
rule set tabstop 2
rule set tabexpand on

# json
client is acme
event is open
query matches '*.json'
rule set tabstop 2
rule set tabexpand on

# makefile
client is acme
event is open
query matches '*Makefile'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# text
client is acme
event is open
query matches '*.txt'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# shell
client is acme
event is open
query matches '*.rc'
query matches '*.sh'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# c
client is acme
event is open
query matches '*.c'
query matches '*.h'
rule set comfmt '/* %s */'
rule set tabstop 8
rule set tabexpand off

# html
client is acme
event is open
query matches '*.html'
rule set comfmt '<!-- %s -->'
rule set tabstop 2
rule set tabexpand on

# markdown
client is acme
event is open
query matches '*.md'
rule set tabstop 2
rule set tabexpand on

# terraform
client is acme
event is open
query matches '*.tf'
rule set comfmt '# %s'
rule set tabstop 2
rule set tabexpand on

# toml
client is acme
event is open
query matches '*.toml'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# yaml
client is acme
event is open
query matches '*.yml'
query matches '*.yaml'
rule set comfmt '# %s'
rule set tabstop 2
rule set tabexpand on

# go (including go.mod, go.sum)
client is acme
event is open
query matches '*.go'
query matches '.*(\.go|go\.mod|go\.sum)$'
rule set comfmt '// %s'
rule set tabstop 8
rule set tabexpand off
