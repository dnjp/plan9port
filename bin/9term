#!/bin/bash
# 9term — launch the 9term terminal with the correct environment and font settings.
#
# This script wraps 9term.bin so that:
#   - The font default is applied when not set by the environment.
#   - The process is named "9term" (not the binary path or "arch"), which is
#     what the macOS menu bar, skhd, and pgrep expect.
#   - The correct architecture is selected on Apple Silicon Macs.
#
# When invoked from 9term.app (INSIDE_9TERM=true), the login environment is
# sourced first so that PLAN9, PATH, and user settings are available.

PLAN9=${PLAN9:-/usr/local/plan9}

# 9term.app launches this script before the login shell environment is loaded.
if [[ "${INSIDE_P9P}" == "true" ]]; then
	cd "$HOME"
	# Preserve devdraw client vars across profile sourcing.
	_saved_wsysid="$wsysid"
	_saved_ddns="$DEVDRAW_NAMESPACE"
	_saved_ns="$NAMESPACE"
	fshell=$(finger "$(whoami)" 2>/dev/null | sed -n 's/.*Shell: //p' | sed 1q)
	fshell=${fshell:-$SHELL}
	case "$fshell" in
	*/bash)  [[ -f ~/.bash_profile ]] && . ~/.bash_profile ;;
	*/zsh)   [[ -f ~/.zprofile    ]] && . ~/.zprofile ;;
	*)       [[ -f ~/.profile     ]] && . ~/.profile ;;
	esac
	if [[ ":$PATH:" != *":$PLAN9/bin:"* ]]; then
		PATH=$PATH:$PLAN9/bin
	fi
	echo -------------------------------
	echo _saved_wsysid="$wsysid" >> /tmp/9term.log
	echo _saved_ddns="$DEVDRAW_NAMESPACE" >> /tmp/9term.log
	echo _saved_ns="$NAMESPACE" >> /tmp/9term.log
	[[ -n "$_saved_wsysid" ]] && export wsysid="$_saved_wsysid"
	[[ -n "$_saved_ddns"   ]] && export DEVDRAW_NAMESPACE="$_saved_ddns"
	[[ -n "$_saved_ns"     ]] && export NAMESPACE="$_saved_ns"
	unset _saved_wsysid _saved_ddns _saved_ns
fi

# Ensure NAMESPACE is set so plan9port services (plumber, etc.) are reachable.
# NOTE: using static namespace given that 9term doesn't currently mount anything
#       and depends on devdraw to already be running there. If this changes in
#       the future, then use the calculated namespace from mac-screen.m.
: "${NAMESPACE:=/tmp/ns.${USER}.:0}"
# export NAMESPACE=/tmp/ns.${USER}.:0
if [ ! -d "$NAMESPACE" ]; then
	mkdir $NAMESPACE
fi

# Apply font defaults if not already set.
# fixfont: monospace font for terminal text.
# varfont: proportional font for popup menus (button 2).
if [[ -f "$PLAN9/shell/fonts.sh" ]]; then
	. "$PLAN9/shell/fonts.sh"
fi
: "${fixfont:=/mnt/font/Menlo-Regular/15a/font,/mnt/font/Menlo-Regular/30a/font}"
: "${varfont:=/mnt/font/LucidaGrande/14a/font,/mnt/font/LucidaGrande/28a/font}"

# Select the native architecture on Apple Silicon so we don't run under Rosetta.
arch=x86_64
if arch -arch arm64 true >/dev/null 2>&1; then
	arch=arm64
fi

# exec -a 9term ensures argv[0] is "9term" so the macOS menu bar and pgrep see
# the process as "9term" rather than the full binary path.
# "$PLAN9/bin/9term.bin" -s -f "$fixfont" -F "$varfont" "$@" > /tmp/9term.log 2>&1
exec arch -arch "$arch" \
	/bin/bash -c 'exec -a 9term "$@"' -- "$PLAN9/bin/9term.bin" -s -f "$fixfont" -F "$varfont" "$@"
