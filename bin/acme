#!/bin/bash
# acme — launch the acme editor with the correct environment and font settings.
#
# This script wraps acme.bin so that:
#   - Font and dump defaults are applied when not set by the environment.
#   - The process is named "acme" (not the binary path or "arch"), which is
#     what the macOS menu bar, skhd, and pgrep expect.
#   - The correct architecture is selected on Apple Silicon Macs.
#   - Namespace collisions are handled when a second acme is launched.
#
# The login environment is sourced whenever it hasn't been loaded yet —
# detected by the absence of fixfont, which plan9.sh always sets. This covers
# both the Acme.app launch path and the plumber's plumb-edit launch path.

PLAN9=${PLAN9:-/usr/local/plan9}

# Set the working directory. P9P_START_DIR is set by plumb-edit to the
# directory of the file being opened, giving acme a meaningful initial cwd.
# When launched from the app bundle with no file context, fall back to $HOME.
# On a plain terminal launch, leave cwd as-is.
if [[ -n "$P9P_START_DIR" ]]; then
	cd "$P9P_START_DIR"
	unset P9P_START_DIR
elif [[ -n "$INSIDE_P9P" ]]; then
	cd "$HOME"
fi

# Source the user's login profile if it hasn't been loaded yet.
# We use fixfont as the sentinel: plan9.sh always sets it, so its absence
# means we're running in a minimal environment (app bundle or plumber spawn).
if [[ -z "$fixfont" ]]; then
	# Preserve devdraw client vars across profile sourcing — the profile
	# may reset or unset them.
	_saved_wsysid="$wsysid"
	_saved_ddns="$DEVDRAW_NAMESPACE"
	_saved_ns="$NAMESPACE"
	fshell=$(finger "$(whoami)" 2>/dev/null | sed -n 's/.*Shell: //p' | sed 1q)
	fshell=${fshell:-$SHELL}
	case "$fshell" in
	*/bash)  [[ -f ~/.bash_profile ]] && . ~/.bash_profile ;;
	*/zsh)   [[ -f ~/.zprofile    ]] && . ~/.zprofile ;;
	*)       [[ -f ~/.profile     ]] && . ~/.profile ;;
	esac
	if [[ ":$PATH:" != *":$PLAN9/bin:"* ]]; then
		PATH=$PATH:$PLAN9/bin
	fi
	# Restore devdraw client vars if they were set before sourcing.
	[[ -n "$_saved_wsysid" ]] && export wsysid="$_saved_wsysid"
	[[ -n "$_saved_ddns"   ]] && export DEVDRAW_NAMESPACE="$_saved_ddns"
	[[ -n "$_saved_ns"     ]] && export NAMESPACE="$_saved_ns"
	unset _saved_wsysid _saved_ddns _saved_ns
fi

# Apply font and dump defaults if not already set.
# Font defaults are defined in $PLAN9/shell/fonts.sh — source it if fixfont
# wasn't already set by the login profile.
if [[ -z "$fixfont" ]]; then
	. "${PLAN9}/shell/fonts.sh"
fi
: "${acmedump:=$HOME/acme.dump}"

ARGS=()
# autoindent
ARGS+=(-a)
# fonts
ARGS+=(-F "$fixfont")
ARGS+=(-f "$varfont")
# load dump file if it exists
# TODO: fix this so that it only loads on the first time acme is opened
# if [[ -f "$acmedump" ]]; then
	# ARGS+=(-l "$acmedump")
# fi

# Handle namespace collisions when launched directly from the terminal
# (not via devdraw/Acme.app).  When $wsysid is set, devdraw has already
# assigned the correct $NAMESPACE for this window — use it as-is.
if [[ -z "$wsysid" ]]; then
	if "$PLAN9/bin/9p" stat acme >/dev/null 2>&1; then
		# Another acme is already running in this namespace; find a free slot.
		# Increment the display number (:0 → :1 → :2 …) for predictability.
		base_ns="${NAMESPACE:-$("$PLAN9/bin/namespace" 2>/dev/null)}"
		if [[ "$base_ns" =~ ^(.*:)([0-9]+)$ ]]; then
			prefix="${BASH_REMATCH[1]}"
			n="${BASH_REMATCH[2]}"
			while true; do
				n=$((n + 1))
				ns="${prefix}${n}"
				mkdir -p "$ns" 2>/dev/null
				# Check if acme is already posted in this candidate namespace.
				if ! NAMESPACE="$ns" "$PLAN9/bin/9p" stat acme >/dev/null 2>&1; then
					break
				fi
			done
		else
			ns=/tmp/ns.$USER.$RANDOM
			mkdir -p "$ns"
		fi
		export NAMESPACE="$ns"
	else
		rm -f "$("$PLAN9/bin/namespace" 2>/dev/null)"/acme 2>/dev/null || true
	fi
fi

# Select the native architecture on Apple Silicon so we don't run under Rosetta.
arch=x86_64
if arch -arch arm64 true >/dev/null 2>&1; then
	arch=arm64
fi

# exec -a acme ensures argv[0] is "acme" so the macOS menu bar and pgrep see
# the process as "acme" rather than the full binary path.
exec arch -arch "$arch" \
	/bin/bash -c 'exec -a acme "$@"' -- "$PLAN9/bin/acme.bin" "${ARGS[@]}" "$@"
