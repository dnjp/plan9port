#!/usr/bin/env bash
# acme-start — launch acme with the correct architecture and font settings.
# Used by Acme.app and by the plumber's start rule when acme is not running.

PLAN9=${PLAN9:-/usr/local/plan9}

arch=x86_64
if arch -arch arm64 date >/dev/null 2>&1; then
	arch=arm64
fi

# Apply defaults for font and dump settings if not set by the environment.
# These use fontsrv-served macOS system fonts with HiDPI (Retina) variants.
# Users can override by setting these variables before launching acme.
# fixfont/varfont match the naming used by startacme, start9term, and acme(1).
: "${fixfont:=/mnt/font/Menlo-Regular/14a/font,/mnt/font/Menlo-Regular/28a/font}"
: "${varfont:=/mnt/font/LucidaGrande/13a/font,/mnt/font/LucidaGrande/26a/font}"
: "${acmedump:=$HOME/acme.dump}"

ARGS=()
if [[ -n "$fixfont" ]]; then
	ARGS+=(-F "$fixfont")
fi
if [[ -n "$varfont" ]]; then
	ARGS+=(-f "$varfont")
fi
if [[ -n "$acmedump" && -f "$acmedump" ]]; then
	ARGS+=(-l "$acmedump")
fi

# If acme is already mounted in the current namespace, create a fresh one.
if "$PLAN9/bin/9p" stat acme >/dev/null 2>&1; then
	ns=/tmp/ns.$USER.$RANDOM
	mkdir -p "$ns"
	export NAMESPACE="$ns"
else
	rm -f "$(namespace 2>/dev/null)"/acme 2>/dev/null || true
fi

# acme-exec wraps the binary with exec -a acme so the process is named "acme"
# (not the full path), which is what the macOS menu bar and skhd expect.
exec arch -arch "$arch" "$PLAN9/bin/acme-exec" -a "${ARGS[@]}"
