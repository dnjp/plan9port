#!/bin/bash
# plumb-edit — open a file in acme, starting acme first if needed.
# Called by the plumber's start rule when no editor client is listening.
# Usage: plumb-edit file [addr]

PLAN9=${PLAN9:-/usr/local/plan9}
file="$1"
addr="$2"

# Start acme if not running, then wait for its 9P server.
if ! "$PLAN9/bin/9p" stat acme > /dev/null 2>&1; then
	if [[ "$(uname)" == "Darwin" ]] && [[ -d "/Applications/Acme.app" ]]; then
		open -a Acme.app
	else
		"$PLAN9/bin/acme" &
	fi
	# Wait up to 10 seconds for acme's 9P server to come up.
	for i in $(seq 1 20); do
		"$PLAN9/bin/9p" stat acme > /dev/null 2>&1 && break
		sleep 0.5
	done
	if ! "$PLAN9/bin/9p" stat acme > /dev/null 2>&1; then
		echo "plumb-edit: timed out waiting for acme" >&2
		exit 1
	fi
fi

# Send directly to acme's edit port.
# Using -d edit avoids re-running the plumber rules (which would call
# plumb-edit again, creating a loop).
if [ -n "$addr" ]; then
	"$PLAN9/bin/plumb" -d edit -a "addr=$addr" "$file"
else
	"$PLAN9/bin/plumb" -d edit "$file"
fi
