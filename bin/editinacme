#!/usr/local/plan9/bin/rc
# editinacme - open a file in acme and wait until its window is deleted.
# Intended for use as $EDITOR in environments where acme is running.
# If acme is not running it is started automatically.
# Usage: editinacme file

if(~ $#PLAN9 0)
	PLAN9=/usr/local/plan9
path=($PLAN9/bin $path)

if(! ~ $#* 1) {
	echo 'usage: editinacme file' >[1=2]
	exit usage
}

file=`{realpath $1}
file=$file(1)

echo 'editinacme: editing '$file >[1=2]

# Start acme if it is not already running.
if(! 9p stat plumb/edit >/dev/null >[2]/dev/null) {
	if(! 9p stat acme >/dev/null >[2]/dev/null)
		acme &
	# Wait up to 10 seconds for acme to register its plumb edit port.
	i=0
	while(! 9p stat plumb/edit >/dev/null >[2]/dev/null) {
		if(~ $i 20) {
			echo 'editinacme: timed out waiting for acme plumb port' >[1=2]
			exit 'acme timeout'
		}
		sleep 0.5
		i=`{echo $i | awk '{print $1+1}'}
	}
}

plumb -s editinacme -d edit $file
if(! ~ $status '') {
	echo 'editinacme: plumb failed' >[1=2]
	exit 'plumb failed'
}

# Wait for the window to be deleted. awk exits (closing the pipe cleanly)
# as soon as it sees the del event for our file, avoiding a broken pipe.
9p read acme/log | awk -v file=$file '$2=="del" && $3==file {exit}'
