#!/usr/local/plan9/bin/rc
# Guide - open the nearest acme guide file.  Traverses up from the
# current window's file (or the given path) until it finds a file
# named "guide", then prints (-p) or opens it in Acme. If starting
# from an existing guide file, it will traverse up until it finds
# another guide file.

if(~ $#PLAN9 0)
	PLAN9=/usr/local/plan9
path=($PLAN9/bin $path)

fn usage {
	echo 'usage: Guide [-p] [path]' >[1=2]
	echo '  Run inside Acme with no path, or pass a path when run from shell.' >[1=2]
	exit usage
}

# Source acme helpers when running inside Acme ($winid set by Acme).
if(! ~ $#winid 0)
	. $PLAN9/lib/acme.rc

fn findguide {
	if(test -f $1/guide)
		echo $1/guide
	if not
		findguide `{dirname $1}
}

print=0
argpath=()
switch($#*){
	case 0
	case 1
		if(~ $1 -p)
			print=1
		if not
			argpath=$1
	case 2
		if(~ $1 -p) {
			print=1
			argpath=$2
		}
		if not {
			usage
		}
	case *
		usage
}

if(! ~ $#argpath 0 && ~ $argpath -*) {
	echo 'Guide: unknown option '$argpath >[1=2]
	usage
}

if(! ~ $#winid 0)
	currentpath=$samfile
if(~ $#currentpath 0 && ! ~ $#argpath 0)
	currentpath=$argpath
if(~ $#currentpath 0) {
	if(~ $#winid 0) {
		echo 'Guide: not running inside Acme and no path was provided.' >[1=2]
		usage
	}
	# In Acme but tag has no path (e.g. new window); use cwd.
	currentpath=`{pwd}
	currentpath=$currentpath(1)
}

# Expand to absolute path; if that fails (e.g. new buffer), use path as-is for dirname.
fullpath=`{realpath $currentpath >[2]/dev/null}
if(~ $status '')
	fullpath=$fullpath(1)
if not
	fullpath=$currentpath

# find parent by going up a directory
if(~ $fullpath */guide)
	fullpath=`{dirname `{dirname $fullpath}}


# use directory if that is the starting point
if(test -d $fullpath)
	startdir=$fullpath
if not
	startdir=`{dirname $fullpath}

guidepath=`{findguide $startdir}

if(~ $#guidepath 0) {
	echo 'Guide: no guide file found from '^$startdir >[1=2]
	exit 1
}

if(~ $print 1)
	echo $guidepath
if not
	plumb -d edit $guidepath
