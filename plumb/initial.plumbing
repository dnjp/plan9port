# to update: cat $HOME/lib/plumbing | 9p write plumb/rules
#
# This is the default plumbing rules file. User-specific settings such as
# home directory paths should be set in $HOME/lib/plumbing instead, e.g.:
#
#   homedir = /Users/you
#   home = /Users/you
#   editor = plumb-edit
#   include basic
#
# The plumber does not expand shell variables, so paths must be literal.

editor = plumb-edit
include basic

