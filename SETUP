#!/bin/sh

git remote add upstream https://github.com/9fans/plan9port.git

export PLAN9=/usr/local/plan9

# TODO: add flag for a "clean" build which executes the following. This is
# probably not the best approach an initial setup on a new system.
sudo rm -rf /usr/local/plan9/*
sudo mkdir -p /usr/local/plan9
sudo cp -r ./* /usr/local/plan9/
cd /usr/local/plan9
sudo ./INSTALL


# Setup path to use plan9 utilities in following steps
export PATH=$PATH:$PLAN9/bin
# make sure we are where we expect
cd /usr/local/plan9

# Generate shell environment files with the actual install path baked in.
# Delegated to shell/mkfile so you can re-run this step independently:
#   cd /usr/local/plan9/shell && mk install-sudo
PLAN9=`pwd`
(cd shell && PLAN9=$PLAN9 $PLAN9/bin/mk install-sudo)

# On macOS, install and start the background daemons (plumber, fontsrv, ruler).
if [ "$(uname)" = "Darwin" ]; then
	(cd mac && ../bin/mk daemons && ../bin/mk load)
fi

echo
echo "plan9port installed to $PLAN9"
echo
echo "Add plan9port to your shell environment by sourcing the appropriate file:"
echo
echo "  bash/zsh/sh:"
echo "    . $PLAN9/shell/plan9.sh"
echo
echo "  fish:"
echo "    source $PLAN9/shell/plan9.fish"
echo
echo "  rc:"
echo "    . $PLAN9/shell/plan9.rc"
echo
echo "Add one of the above lines to your shell profile (~/.bash_profile,"
echo "~/.zprofile, ~/.config/fish/config.fish, etc.) to make it permanent."
echo
if [ "$(uname)" = "Darwin" ]; then
	echo "macOS LaunchAgents for plumber, fontsrv, and ruler have been installed"
	echo "and started. They will start automatically at login."
	echo
fi
echo "To setup plan9port mail, follow these steps:"
echo
echo "  cd $PLAN9/src/cmd/upas/nfs && mk install"
echo "  cd $PLAN9/src/cmd/upas && mk install"
echo
