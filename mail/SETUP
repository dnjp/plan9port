#!/usr/local/plan9/bin/rc
path=(/usr/local/plan9/bin $path)

# Run mk targets for account blocks in $PLAN9/mail/accounts.
#
# Usage:
#   ./SETUP                       # set up all accounts (runs 'account' target for each)
#   ./SETUP <mk-target> [name ... | all]
#
# Examples:
#   ./SETUP                       # account + auth + daemon-load for every account
#   ./SETUP account work          # full setup for the 'work' account only
#   ./SETUP auth work             # reload credentials for 'work'
#   ./SETUP daemon-load all       # (re)start all account daemons
#   ./SETUP refresh work          # force inbox refresh for 'work'

if(~ $#PLAN9 0)
	PLAN9=/usr/local/plan9

target=account
selectors=(all)
if(! ~ $#* 0){
	target=$1
	shift
	if(! ~ $#* 0)
		selectors=$*
}

mkfile=$PLAN9/mail/mkfile
accounts=$PLAN9/mail/accounts
maildir=$PLAN9/mail

if(! test -f $accounts){
	echo 'missing accounts file: '^$accounts >[1=2]
	echo 'copy accounts.example to accounts and fill in your details' >[1=2]
	exit 1
}

# Generate lib/rewrite from all accounts (single catch-all rule; qmail routes by From:).
awk -v maildir=$maildir '
function trim(s){sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s}
function flush(){
	if(name != "" || account != "" || imap != "" || smtp != "" || srv != "")
		n++
	name = account = imap = smtp = srv = ""
}
{
	line = trim($0)
	if(line ~ /^#/) next
	if(line == ""){ flush(); next }
	if(index(line, "=") == 0) next
	key = line; sub(/=.*/, "", key)
	val = line; sub(/^[^=]*=/, "", val)
	if(key == "name") name = val
	else if(key == "account") account = val
	else if(key == "imap") imap = val
	else if(key == "smtp") smtp = val
	else if(key == "srv") srv = val
}
END {
	flush()
	if(n == 0) exit 1
	print "# Generated by $PLAN9/mail/SETUP from $PLAN9/mail/accounts. DO NOT EDIT."
	print "([^@]+)@([^@]+)@(.+)\talias\t\t\\2!\\1@\\3"
	print "([^@]+)@([^@]+)\t\talias\t\t\\2!\\1"
	print ""
	print "# Single catch-all: lib/qmail reads the From: header to pick"
	print "# the right SMTP server from accounts, so routing is always sender-based."
	printf("([^!]+)!(.*)\t\t|\t\t\"%s/lib/qmail\"\t\"\\2@\\1\"\n", maildir)
}
' $accounts > $maildir/lib/rewrite || exit 1

# Generate lib/remotemail from all accounts (dispatches by sender address).
awk -v plan9=$PLAN9 '
function trim(s){sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s}
function flush(){
	if(account != "")
		acc[++n] = account
	name = account = imap = smtp = srv = ""
}
{
	line = trim($0)
	if(line ~ /^#/) next
	if(line == ""){ flush(); next }
	if(index(line, "=") == 0) next
	key = line; sub(/=.*/, "", key)
	val = line; sub(/^[^=]*=/, "", val)
	if(key == "name") name = val
	else if(key == "account") account = val
	else if(key == "imap") imap = val
	else if(key == "smtp") smtp = val
	else if(key == "srv") srv = val
}
END {
	flush()
	if(n == 0) exit 1
	print "#!/usr/local/plan9/bin/rc"
	print "# Generated by $PLAN9/mail/SETUP from $PLAN9/mail/accounts. DO NOT EDIT."
	print "path=(" plan9 "/bin $path)"
	print "shift"
	print "sender=$1"
	print "shift"
	print "addr=$1"
	print "shift"
	print "smtpuser=()"
	print "switch($sender){"
	for(i=1; i<=n; i++)
		printf("case %s\n\tsmtpuser=%s\n", acc[i], acc[i])
	print "case *"
	printf("\tif(! ~ $sender *@*)\n\t\tsmtpuser=%s\n", acc[1])
	print "\tif(~ $#smtpuser 0)"
	print "\t\tsmtpuser=$sender"
	print "}"
	print "if(! ~ $sender *@*)"
	print "\tsender=$smtpuser"
	printf("exec %s/bin/upas/smtp -a -u $smtpuser $addr $sender $*\n", plan9)
}
' $accounts > $maildir/lib/remotemail || exit 1
chmod +x $maildir/lib/remotemail

# Extract account records for per-account mk runs.
records=`{awk '
function trim(s){sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s}
function flush(){
	if(name != "" || account != "" || imap != "" || smtp != "" || srv != "")
		print name "|" account "|" imap "|" smtp "|" srv
	name = account = imap = smtp = srv = ""
}
{
	line = trim($0)
	if(line ~ /^#/){ next }
	if(line == ""){ flush(); next }
	if(index(line, "=") == 0){ next }
	key = line; sub(/=.*/, "", key)
	val = line; sub(/^[^=]*=/, "", val)
	if(key == "name") name = val
	else if(key == "account") account = val
	else if(key == "imap") imap = val
	else if(key == "smtp") smtp = val
	else if(key == "srv") srv = val
}
END { flush() }
' $accounts}

failed=0
for(rec in $records){
	name=`{echo $rec | awk -F'|' '{print $1}'}
	account=`{echo $rec | awk -F'|' '{print $2}'}
	imap=`{echo $rec | awk -F'|' '{print $3}'}
	smtp=`{echo $rec | awk -F'|' '{print $4}'}
	srv=`{echo $rec | awk -F'|' '{print $5}'}

	if(~ $#name 0 || ~ $#account 0 || ~ $#imap 0 || ~ $#smtp 0 || ~ $#srv 0){
		echo 'incomplete account block for '^$name^' in '^$accounts >[1=2]
		failed=1
	}

	if(! ~ $#name 0){
		if(~ $selectors all || ~ $name $selectors){
			echo running mk $target for $name
			mk -f $mkfile \
				MAILDIR=$maildir PLAN9=$PLAN9 \
				MAIL_TAG=$name ACCOUNT=$account \
				IMAPSERVER=$imap SMTPSERVER=$smtp \
				MAIL_SRVNAME=$srv \
				$target
			mkstatus=$status
			if(! ~ $mkstatus ''){
				failed=1
			}
			if(~ $mkstatus ''){
				if(! ~ $target auth){
					echo $PLAN9/bin/Mail -n $srv
				}
			}
		}
	}
}
exit $failed
