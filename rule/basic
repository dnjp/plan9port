# Ruler rules (plumber-style). Blank line terminates each rule set.
# See https://9fans.github.io/plan9port/man/man7/ruler.html
# All rules: client=acme, event=open (window opened).
#
# font=fix uses the fixed-width font (fixfont); font=var uses the proportional
# font (varfont). Source code uses fix; prose and markup use var.

# win(1) terminal windows
client is acme
event is open
type is win
rule set font fix

# text
client is acme
event is open
query matches '*.txt'
rule set font var
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# shell
client is acme
event is open
query matches '*.rc'
query matches '*.sh'
query matches '*.zsh'
query matches '*.bash'
query matches '*/.profile'
query matches '*/.bashrc'
query matches '*/.bash_profile'
query matches '*/.bash_logout'
query matches '*/.zshrc'
query matches '*/.zprofile'
query matches '*/.zshenv'
rule set font fix
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# make
client is acme
event is open
query matches '*Makefile'
query matches '*mkfile'
rule set font fix
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# html
client is acme
event is open
query matches '*.html'
rule set font fix
rule set comfmt '<!-- %s -->'
rule set tabstop 2
rule set tabexpand on

# markdown
client is acme
event is open
query matches '*.md'
rule set font var
rule set tabstop 2
rule set tabexpand on

# c
client is acme
event is open
query matches '*.c'
query matches '*.h'
rule set font fix
rule set comfmt '/* %s */'
rule set tabstop 8
rule set tabexpand off

# go (including go.mod, go.sum)
client is acme
event is open
query matches '*.go'
query matches '.*(\.go|go\.mod|go\.sum)$'
rule set font fix
rule set comfmt '// %s'
rule set tabstop 8
rule set tabexpand off

# Default
client is acme
event is open
query matches '.*'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off
