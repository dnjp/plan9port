# Ruler rules (plumber-style). Blank line terminates each rule set.
# See https://9fans.github.io/plan9port/man/man7/plumb.html
# All rules: client=acme, event=new (new window opened).

# text
client is acme
event is open
query matches '*.txt'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# shell
client is acme
event is open
query matches '*.rc'
query matches '*.sh'
query matches '*.zsh'
query matches '.*.(profile|.*rc)$'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# make
client is acme
event is open
query matches '*Makefile'
query matches '*mkfile'
rule set comfmt '# %s'
rule set tabstop 8
rule set tabexpand off

# html
client is acme
event is open
query matches '*.html'
rule set comfmt '<!-- %s -->'
rule set tabstop 2
rule set tabexpand on

# markdown
client is acme
event is open
query matches '*.md'
rule set tabstop 2
rule set tabexpand on

# c
client is acme
event is open
query matches '*.c'
query matches '*.h'
rule set comfmt '/* %s */'
rule set tabstop 8
rule set tabexpand off

# go (including go.mod, go.sum)
client is acme
event is open
query matches '*.go'
query matches '.*(\.go|go\.mod|go\.sum)$'
rule set comfmt '// %s'
rule set tabstop 8
rule set tabexpand off

