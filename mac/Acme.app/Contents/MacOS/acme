#!/bin/bash
export INSIDE_P9P=true
export INSIDE_ACME=true
export tabstop=8

PLAN9=${PLAN9:-/usr/local/plan9}
export PLAN9
export PATH="$PLAN9/bin:$PATH"

# Point libdraw at the devdraw binary inside this bundle so that the
# display server process inherits the bundle's icon and app name.
export DEVDRAW="$(dirname "$0")/devdraw"

exec "$PLAN9/bin/acme"
