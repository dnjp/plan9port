PLAN9=$PLAN9
HOME=$HOME
LAUNCH_AGENTS=$HOME/Library/LaunchAgents
LOG_DIR=$HOME/.local/var/log/plan9port
# Absolute path to this daemons/ directory (scripts referenced directly from plists).
DAEMONDIR=`pwd`/daemons

DAEMONS=com.plan9port.fontsrv com.plan9port.plumber com.plan9port.ruler com.plan9port.factotum

all:V: install

# Install .app bundles and daemons.
install:V: apps daemons deps

deps:V:
	brew bundle install

# Build devdraw from source (must be done before updating app bundles).
build-devdraw:V:
	cd $PLAN9/src/cmd/devdraw && $PLAN9/bin/mk install

# Copy .app bundles to /Applications and install helper scripts to $PLAN9/bin.
# devdraw is copied from $PLAN9/bin into each bundle's MacOS/ directory so
# that macOS associates the display server process with the correct bundle
# (icon, app name, Dock entry) rather than showing a generic devdraw entry.
# /Applications is root-owned, so sudo is used for copies there.
# Run build-devdraw first to ensure the binary is up to date.
apps:V: build-devdraw
	sudo cp -r 9term.app /Applications/
	sudo cp $PLAN9/bin/devdraw /Applications/9term.app/Contents/MacOS/devdraw
	sudo codesign --force --deep --sign - /Applications/9term.app
	sudo cp -r Acme.app /Applications/
	sudo cp $PLAN9/bin/devdraw /Applications/Acme.app/Contents/MacOS/devdraw
	sudo codesign --force --deep --sign - /Applications/Acme.app
	sudo cp -r Plumb.app /Applications/
	sudo codesign --force --deep --sign - /Applications/Plumb.app
	cmp -s ../bin/p9p-open $PLAN9/bin/p9p-open || install -m 755 ../bin/p9p-open $PLAN9/bin/p9p-open
	/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f /Applications/Plumb.app
	sudo cp -r Sam.app /Applications/
	sudo cp $PLAN9/bin/devdraw /Applications/Sam.app/Contents/MacOS/devdraw
	sudo codesign --force --deep --sign - /Applications/Sam.app

# Expand plist templates and install LaunchAgents.
# Scripts (run-with-env.sh, 9p-status) are referenced in-place from the source
# tree so no root-owned directories need to be written.
daemons:V:
	mkdir -p $LOG_DIR $LAUNCH_AGENTS
	chmod +x daemons/run-with-env.sh daemons/9p-status daemons/p9p-notify
	for d in $DAEMONS; do \
		sed \
			-e 's|@HOME@|'$HOME'|g' \
			-e 's|@PLAN9@|'$PLAN9'|g' \
			-e 's|@DAEMONDIR@|'$DAEMONDIR'|g' \
			daemons/$d.plist.template > $LAUNCH_AGENTS/$d.plist; \
		echo installed $LAUNCH_AGENTS/$d.plist; \
	done
	echo 'Daemons installed. Run mk load to start them.'

# Load (start) all LaunchAgents.
# launchctl load/unload are deprecated since macOS 10.10; use bootstrap/bootout.
# bootout first (ignored if not loaded) so bootstrap never fails on re-runs.
load:V:
	for d in $DAEMONS; do \
		launchctl bootout gui/`id -u` $LAUNCH_AGENTS/$d.plist 2>/dev/null || true; \
		launchctl bootstrap gui/`id -u` $LAUNCH_AGENTS/$d.plist; \
		echo loaded $d; \
	done

# Unload (stop) all LaunchAgents.
unload:V:
	for d in $DAEMONS; do \
		launchctl bootout gui/`id -u` $LAUNCH_AGENTS/$d.plist 2>/dev/null || true; \
		echo unloaded $d; \
	done

# Unload then load (restart after editing plists or run-with-env.sh).
# bootstrap fails if already loaded, so always bootout first (errors ignored).
reload:V:
	for d in $DAEMONS; do \
		launchctl bootout gui/`id -u` $LAUNCH_AGENTS/$d.plist 2>/dev/null || true; \
		launchctl bootstrap gui/`id -u` $LAUNCH_AGENTS/$d.plist; \
		echo reloaded $d; \
	done

# Show status of all LaunchAgents.
status:V:
	sh daemons/9p-status

# Tail all plan9port daemon logs.
logs:V:
	sh daemons/9p-status tail

# Install/load a per-account mailfs LaunchAgent from template.
# Not included in DAEMONS by default (fresh clones have no account config).
#
# Usage:
#   mk mailfs-daemon MAIL_TAG=posteo MAIL_USER=you@posteo.net MAIL_SERVER=posteo.de
# Optional:
#   MAIL_SRVNAME=mail.posteo   # 9p service/socket name (default: mail)
mailfs-daemon:V:
	mkdir -p $LOG_DIR $LAUNCH_AGENTS
	if test -z "$MAIL_TAG" || test -z "$MAIL_USER" || test -z "$MAIL_SERVER"; then \
		echo "usage: mk mailfs-daemon MAIL_TAG=tag MAIL_USER=user@domain MAIL_SERVER=imap.host [MAIL_SRVNAME=mail]"; \
		exit 1; \
	fi
	if test -z "$MAIL_SRVNAME"; then MAIL_SRVNAME=mail; fi
	sed \
		-e 's|@HOME@|'$HOME'|g' \
		-e 's|@PLAN9@|'$PLAN9'|g' \
		-e 's|@DAEMONDIR@|'$DAEMONDIR'|g' \
		-e 's|@MAIL_TAG@|'$MAIL_TAG'|g' \
		-e 's|@MAIL_USER@|'$MAIL_USER'|g' \
		-e 's|@MAIL_SERVER@|'$MAIL_SERVER'|g' \
		-e 's|@MAIL_SRVNAME@|'$MAIL_SRVNAME'|g' \
		daemons/com.plan9port.mailfs.plist.template > $LAUNCH_AGENTS/com.plan9port.mailfs.$MAIL_TAG.plist
	launchctl bootout gui/`id -u` $LAUNCH_AGENTS/com.plan9port.mailfs.$MAIL_TAG.plist 2>/dev/null || true
	launchctl bootstrap gui/`id -u` $LAUNCH_AGENTS/com.plan9port.mailfs.$MAIL_TAG.plist
	echo installed+loaded $LAUNCH_AGENTS/com.plan9port.mailfs.$MAIL_TAG.plist

mailfs-daemon-unload:V:
	if test -z "$MAIL_TAG"; then \
		echo "usage: mk mailfs-daemon-unload MAIL_TAG=tag"; \
		exit 1; \
	fi
	launchctl bootout gui/`id -u` $LAUNCH_AGENTS/com.plan9port.mailfs.$MAIL_TAG.plist 2>/dev/null || true
	echo unloaded com.plan9port.mailfs.$MAIL_TAG

mailfs-daemon-reload:V: mailfs-daemon-unload mailfs-daemon

# Register Plumb.app as the default handler for text and source-code file types.
#
# macOS exposes no native shell API for this — the underlying call is
# LSSetDefaultRoleHandlerForContentType, which requires compiled code.
# duti (https://github.com/moretension/duti) is the standard thin wrapper
# around that API.  Install with: brew install duti
#
# Two strategies are used:
#
#   1. Named UTIs  — covers all files macOS recognises as that type, regardless
#      of extension.  This is the preferred approach.
#
#   2. Extension fallback — for types macOS assigns a dynamic "dyn.*" UTI to
#      (i.e. it doesn't know the format), we register by extension so Finder
#      still routes double-clicks correctly.
#
# After running this target, re-launch Finder or log out/in if changes don't
# appear immediately.  macOS caches Launch Services associations aggressively.
#
# NOTE: This only sets Plumb.app as the *default*; it does not prevent other
# apps from opening these files.  Specialised document formats (Pages, Word,
# PDF, images, etc.) are intentionally excluded.
register-defaults:V:
	sh -c '\
		if ! command -v duti >/dev/null 2>&1; then \
			echo "error: duti not found. Install with: brew install duti"; \
			exit 1; \
		fi; \
		BUNDLE=com.swtch.plan9port.plumb; \
		echo "==> Registering named UTIs..."; \
		for uti in \
			public.plain-text \
			public.source-code \
			public.script \
			public.shell-script \
			public.bash-script \
			public.zsh-script \
			public.python-script \
			public.ruby-script \
			public.perl-script \
			public.c-source \
			public.c-header \
			public.c-plus-plus-source \
			public.objective-c-source \
			public.make-source \
			com.netscape.javascript-source \
			com.sun.java-source \
			public.yaml \
			public.json \
			net.daringfireball.markdown \
		; do \
			duti -s "$BUNDLE" "$uti" all && echo "  $uti" || echo "  FAILED: $uti"; \
		done; \
		echo "==> Registering extensions (dynamic/unknown UTIs)..."; \
		for ext in \
			ts \
			go \
			rs \
			toml \
			lua \
			vim \
			fish \
			conf \
			rc \
			mk \
			profile \
			gitconfig \
		; do \
			duti -s "$BUNDLE" ".$ext" all && echo "  .$ext" || echo "  FAILED: .$ext"; \
		done; \
		echo "==> Done. You may need to relaunch Finder for changes to take effect." \
	'
