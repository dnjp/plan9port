			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>rc</string>
				</array>
			</dict>
		</dict>

	</array>

	<!--
	  LSBackgroundOnly = false so Plumb appears in the Dock and "Open With"
	  menus when handling files.  (Previously true, which hid it from menus.)
	-->
	<key>LSBackgroundOnly</key>
	<false/>

</dict>
</plist>
